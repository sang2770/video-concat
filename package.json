{
  "name": "video-concat",
  "version": "1.0.0",
  "description": "Video Concatenation Tool with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build-win": "electron-builder --win --publish=never"
  },
  "keywords": [],
  "author": "Kelvin Nguyen",
  "license": "ISC",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "build": {
    "appId": "com.video.concat",
    "productName": "Video Concat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to":   "runtime",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Video Concat"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
